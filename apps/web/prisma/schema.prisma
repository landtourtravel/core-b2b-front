// ==============================================================
// PORTAL DE AGENCIAS — land-tour-client (apps/web)
// ==============================================================
// Este schema SOLO define las tablas nuevas del portal.
// Las tablas de datos maestros (Agencia, User, Paquete, etc.)
// son propiedad de lt-core-admin y se referencian por ID.
//
// IMPORTANTE: Ambas apps apuntan a la misma BD PostgreSQL.
// Nunca hacer `prisma migrate` sobre los modelos de lt-core-admin.
// ==============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ==============================================================
// REFERENCIAS DE SOLO LECTURA (lt-core-admin)
// Estos modelos ya existen en la BD. Se declaran aquí para
// permitir relaciones Prisma y queries de lectura desde el portal.
// Nunca incluir en migraciones nuevas.
// ==============================================================

/// @readonly — gestionado por lt-core-admin
model Agencia {
  id          String   @id
  nombre      String
  descripcion String?  @db.Text
  correo      String?
  telefono    String?
  fechaAlta   DateTime

  usuarios     UsuarioAgencia[]
  clientes     Cliente[]
  cotizaciones Cotizacion[]

  @@map("Agencia")
}

/// @readonly — gestionado por lt-core-admin
model UsuarioAgencia {
  id        String   @id
  name      String?
  email     String?  @unique
  password  String?
  role      String
  agenciaId String?
  agencia   Agencia? @relation(fields: [agenciaId], references: [id], onDelete: SetNull)

  cotizaciones     Cotizacion[]
  historialCambios HistorialCotizacion[]

  @@map("User")
}

/// @readonly — gestionado por lt-core-admin
model DestinoRef {
  id          Int     @id
  pais        String
  ciudad      String
  descripcion String? @db.Text
  imagen      String?

  hoteles     HotelRef[]
  actividades ActividadRef[]
  traslados   TrasladoRef[]

  @@map("Destino")
}

/// @readonly — gestionado por lt-core-admin
model HotelRef {
  id        Int        @id
  destinoId Int
  nombre    String
  estrellas Int

  destino  DestinoRef        @relation(fields: [destinoId], references: [id])
  paquetes PaqueteHotelRef[]
  tarifas  TarifaHotelRef[]

  @@map("Hotel")
}

/// @readonly — gestionado por lt-core-admin
model PaqueteRef {
  id               Int     @id
  nombre           String
  descripcion      String? @db.Text
  incluyeBoleto    Boolean
  precioBoleto     Float?
  descripcionBoleto String? @db.Text
  permitirModificarBoleto Boolean @default(true)
  permitirModificarNoches Boolean @default(false)
  ajustePrecio     Float   @default(0)
  numPax           Int
  numNinos         Int
  diasEstancia     Int
  nochesBase       Int
  precioTotal      Float?
  precioPorPersona Float?
  visibleEnFront   Boolean

  hoteles     PaqueteHotelRef[]
  versiones   VersionPaqueteRef[]
  imagenes    ImagenPaqueteRef[]
  actividades PaqueteActividadRef[]
  traslados   PaqueteTrasladoRef[]
  itinerario  ItinerarioDiaRef[]

  @@map("Paquete")
}

/// @readonly — gestionado por lt-core-admin
model ItinerarioDiaRef {
  id          Int     @id
  paqueteId   Int
  dia         Int
  titulo      String
  descripcion String? @db.Text
  orden       Int

  paquete PaqueteRef @relation(fields: [paqueteId], references: [id])

  @@map("ItinerarioDia")
}

/// @readonly — gestionado por lt-core-admin
model PaqueteHotelRef {
  paqueteId      Int
  hotelId        Int
  tipoHabitacion String
  cantidad       Int
  noches         Int @default(1)

  paquete PaqueteRef @relation(fields: [paqueteId], references: [id])
  hotel   HotelRef   @relation(fields: [hotelId], references: [id])

  @@id([paqueteId, hotelId, tipoHabitacion])
  @@map("PaqueteHotel")
}

/// @readonly — gestionado por lt-core-admin
model ActividadRef {
  id          Int     @id
  destinoId   Int
  nombre      String
  descripcion String? @db.Text

  destino  DestinoRef              @relation(fields: [destinoId], references: [id])
  paquetes PaqueteActividadRef[]
  tarifas  TarifaActividadRef[]

  @@map("Actividad")
}

/// @readonly — gestionado por lt-core-admin
model TrasladoRef {
  id        Int    @id
  destinoId Int
  tipo      String

  destino  DestinoRef             @relation(fields: [destinoId], references: [id])
  paquetes PaqueteTrasladoRef[]
  tarifas  TarifaTrasladoRef[]

  @@map("Traslado")
}

/// @readonly — gestionado por lt-core-admin
model TarifaActividadRef {
  id           Int    @id
  actividadId  Int
  precio       Float
  paxMax       Int
  paxMin       Int
  tipoPasajero String

  actividad ActividadRef @relation(fields: [actividadId], references: [id])

  @@map("TarifaActividad")
}

/// @readonly — gestionado por lt-core-admin
model TarifaTrasladoRef {
  id         Int    @id
  trasladoId Int
  tipoCobro  String
  precio     Float
  paxMax     Int
  paxMin     Int

  traslado TrasladoRef @relation(fields: [trasladoId], references: [id])

  @@map("TarifaTraslado")
}

/// @readonly — gestionado por lt-core-admin
model PaqueteActividadRef {
  paqueteId   Int
  actividadId Int

  paquete   PaqueteRef   @relation(fields: [paqueteId], references: [id])
  actividad ActividadRef @relation(fields: [actividadId], references: [id])

  @@id([paqueteId, actividadId])
  @@map("PaqueteActividad")
}

/// @readonly — gestionado por lt-core-admin
model PaqueteTrasladoRef {
  paqueteId  Int
  trasladoId Int

  paquete  PaqueteRef  @relation(fields: [paqueteId], references: [id])
  traslado TrasladoRef @relation(fields: [trasladoId], references: [id])

  @@id([paqueteId, trasladoId])
  @@map("PaqueteTraslado")
}

/// @readonly — gestionado por lt-core-admin
model VersionPaqueteRef {
  id               Int    @id
  paqueteId        Int
  numPax           Int
  tipoPax          String
  precioTotal      Float?
  precioPorPersona Float?

  paquete PaqueteRef @relation(fields: [paqueteId], references: [id])

  @@unique([paqueteId, tipoPax])
  @@map("VersionPaquete")
}

/// @readonly — gestionado por lt-core-admin
model ImagenPaqueteRef {
  id        Int    @id
  paqueteId Int
  url       String
  orden     Int

  paquete PaqueteRef @relation(fields: [paqueteId], references: [id])

  @@map("ImagenPaquete")
}

/// @readonly — gestionado por lt-core-admin
model TarifaHotelRef {
  id             Int      @id
  hotelId        Int
  tipoHabitacion String   // 'SGL' | 'DBL' | 'TPL' | 'QUAD' | 'CHD'
  precioBase     Float

  hotel HotelRef @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, tipoHabitacion])
  @@map("TarifaHotel")
}

// ==============================================================
// TABLAS NUEVAS — Portal de Cotizaciones
// ==============================================================

/// Cliente final de la agencia (el pasajero / viajero).
/// No es un User del sistema — es el cliente de la agencia minorista.
model Cliente {
  id        String  @id @default(cuid())
  agenciaId String
  agencia   Agencia @relation(fields: [agenciaId], references: [id])

  nombre    String
  email     String?
  telefono  String?
  documento String?
  direccion String?

  fechaAlta DateTime @default(now())

  cotizaciones Cotizacion[]

  @@unique([agenciaId, email])
  @@unique([agenciaId, documento])
}

/// Cotización / Proforma generada por la agencia para un cliente.
model Cotizacion {
  id     String @id @default(cuid())
  codigo String @unique

  // ── Relaciones principales ──────────────────────────────────────────
  agenciaId   String
  agencia     Agencia        @relation(fields: [agenciaId], references: [id])

  creadoPorId String
  creadoPor   UsuarioAgencia @relation(fields: [creadoPorId], references: [id])

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  // Referencia escalar al paquete cotizado (sin relación Prisma para no acoplar
  // el modelo PaqueteRef a la lógica de cotizaciones).
  paqueteId Int?

  // ── Snapshot del paquete — inmutable desde el momento de cotizar ────
  snapshotNombre   String   // Nombre del paquete cotizado
  snapshotDestino  String   // "Ciudad, País"
  snapshotDuracion String   // "5 Días / 4 Noches"
  snapshotIncluye  String[] // Servicios incluidos (texto para la proforma PDF)

  // ── Boleto aéreo (si aplica) ────────────────────────────────────────
  incluyeBoleto Boolean @default(false)
  precioBoleto  Float?  // Precio neto por persona (snapshot de Paquete.precioBoleto)
  boletoTotal   Float   @default(0) // precioBoleto × Σ(detalle.numPax × detalle.cantidad)

  // ── Líneas de detalle (una fila por tipoPax cotizado) ───────────────
  detalles CotizacionDetalle[]

  // ── Totales (fórmula: total = subtotal + boletoTotal + markup) ───────
  subtotal Float              // Σ(detalle.subtotal) — precio neto del paquete
  markup   Float  @default(0) // Comisión de la agencia (no visible al cliente en PDF)
  total    Float              // Precio final al cliente

  // ── Fechas de viaje ─────────────────────────────────────────────────
  fechaViaje   DateTime?
  fechaRetorno DateTime?

  // ── Estado del flujo ────────────────────────────────────────────────
  status          CotizacionStatus @default(BORRADOR)
  notas           String?          @db.Text
  tokenAprobacion String?          @unique @default(cuid())

  // ── Timestamps ──────────────────────────────────────────────────────
  fechaCreacion    DateTime  @default(now())
  fechaEnvio       DateTime?
  fechaAprobacion  DateTime?
  fechaVencimiento DateTime?

  historial HistorialCotizacion[]
}

/// Una fila por tipo de ocupación dentro de una cotización.
/// Permite representar grupos mixtos: 2 DBL + 1 SGL en la misma proforma.
model CotizacionDetalle {
  id           String     @id @default(cuid())
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  // Referencia escalar a la versión cotizada (sin relación Prisma para no acoplar
  // el modelo VersionPaqueteRef a la lógica de cotizaciones).
  versionId Int?

  // ── Snapshot de la versión al momento de cotizar ────────────────────
  tipoPax  String // 'SGL' | 'DBL' | 'TPL' | 'QUAD' | 'CHD'
  numPax   Int    // Pasajeros por unidad (habitación). Snapshot de VersionPaquete.numPax.
  cantidad Int    @default(1) // Número de habitaciones/unidades de este tipoPax

  // ── Precios snapshot — congelados, no cambian aunque cambie VersionPaquete ──
  precioPorPersona Float // Precio neto mayorista por persona
  precioUnitario   Float // precioPorPersona × numPax — precio por habitación/unidad
  subtotal         Float // precioUnitario × cantidad — total para este tipoPax

  @@map("CotizacionDetalle")
}

/// Auditoría de cada cambio de estado en una cotización.
model HistorialCotizacion {
  id String @id @default(cuid())

  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  cambiadoPorId String
  cambiadoPor   UsuarioAgencia @relation(fields: [cambiadoPorId], references: [id])

  statusAnterior CotizacionStatus?
  statusNuevo    CotizacionStatus
  nota           String?

  fecha DateTime @default(now())
}

// ==============================================================
// ENUMS
// ==============================================================

enum CotizacionStatus {
  BORRADOR
  ENVIADA
  APROBADA
  RECHAZADA
}
